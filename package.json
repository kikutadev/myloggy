{
  "name": "myloggy",
  "version": "0.1.0",
  "private": false,
  "description": "Local-first work logging app powered by Electron, SQLite, and Ollama.",
  "author": "Shingo Irie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iritec/myloggy.git"
  },
  "homepage": "https://github.com/iritec/myloggy",
  "bugs": {
    "url": "https://github.com/iritec/myloggy/issues"
  },
  "type": "commonjs",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "predev": "node scripts/check-rollup-native.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json --watch",
    "dev:electron": "electron dist-electron/electron/main.js",
    "prebuild": "node scripts/check-rollup-native.mjs",
    "build": "tsc -p tsconfig.node.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview",
    "dist:mac:prod": "pnpm build && electron-builder --mac --publish never",
    "dist:mac:prod:x64": "pnpm build && electron-builder --mac --x64 --publish never",
    "dist:mac:prod:arm64": "pnpm build && electron-builder --mac --arm64 --publish never"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "dependencies": {
    "dayjs": "^1.11.19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "wait-on": "^9.0.5"
  }
}
